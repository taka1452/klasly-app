{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/trial-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/past-due-check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/grace-check",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/generate-sessions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/event-installments",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/event-installment-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/pass-distribution",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/pass-payout",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/tier-overage-billing",
      "schedule": "0 1 1 * *"
    },
    {
      "path": "/api/cron/class-reminder",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/streak-decay",
      "schedule": "5 0 * * 1"
    },
    {
      "path": "/api/cron/comeback-nudge",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/owner-weekly-summary",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/manager-morning-todo",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/instructor-morning-briefing",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/instructor-low-fill",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/instructor-birthday-alerts",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/instructor-monthly-recap",
      "schedule": "0 14 1 * *"
    }
  ]
}
